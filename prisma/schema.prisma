// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  logoUrl      String?
  brandColor   String?
  billingPlan  String   @default("FREE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  orders       Order[]
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String?        // Hashed password for Credentials provider
  name           String?
  role           Role           @default(STANDARD_USER)
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  designs        Design[]
  orders         Order[]
  recipients     Recipient[]
  groups         RecipientGroup[]
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  TEAM_MANAGER
  STANDARD_USER
}

model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  name            String
  category        String
  description     String?
  basePrice       Float
  isCustomizable  Boolean  @default(true)
  placementZones  Json?    // Stores array of zone metadata
  images          Json?    // Stores array of image URLs
  designs         Design[]
  bundleItems     BundleItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Bundle {
  id        String       @id @default(cuid())
  name      String
  type      BundleType   @default(PRESET)
  price     Float
  createdBy String?      // User ID or Admin
  items     BundleItem[]
  designs   Design[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum BundleType {
  PRESET
  CUSTOM
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
}

model Design {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id])
  productId               String?
  product                 Product?  @relation(fields: [productId], references: [id])
  bundleId                String?
  bundle                  Bundle?   @relation(fields: [bundleId], references: [id])
  intentPrompt            String?   @db.Text // max 500 chars
  logoUrl                 String?
  textLine1               String?
  textLine2               String?
  placementHint           String?
  textColor               String?
  fontStyleHint           String?
  aiInterpretationSummary String?
  previewImageUrl         String?
  status                  DesignStatus @default(DRAFT)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  orders                  Order[]
}

enum DesignStatus {
  DRAFT
  APPROVED
}

model Order {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  orgId         String?
  organization  Organization? @relation(fields: [orgId], references: [id])
  designId      String
  design        Design    @relation(fields: [designId], references: [id])
  giftingMode   GiftingMode
  status        OrderStatus @default(DRAFT)
  totalAmount   Float
  deliverySpeed String    @default("STANDARD")
  scheduledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orderRecipients OrderRecipient[]
}

enum GiftingMode {
  SINGLE
  BULK
  SELF
}

enum OrderStatus {
  DRAFT
  AWAITING_ADDRESS
  PROCESSING
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
  REFUND_REQUESTED
}

model OrderRecipient {
  id                 String    @id @default(cuid())
  orderId            String
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recipientName      String?
  email              String?
  phone              String?
  address            Json?     // Stores address object
  status             RecipientStatus @default(PENDING)
  trackingNumber     String?
  carrier            String?
  giftMessage        String?   @db.Text
  addressSubmittedAt DateTime?
  deliveredAt        DateTime?
}

enum RecipientStatus {
  PENDING
  AWAITING_ADDRESS
  PROCESSING
  SHIPPED
  DELIVERED
}

model Recipient {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  address   Json?    // Stores address object
  tags      String[]
  groups    RecipientGroup[] @relation("RecipientToGroup")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipientGroup {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  orgId     String?
  name      String
  members   Recipient[] @relation("RecipientToGroup")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
